#include <vector>

class Solution {
    int rows[9] = {0}, cols[9] = {0}, boxes[9] = {0};

public:
    void solveSudoku(std::vector<std::vector<char>>& board) {
        // 1. Initialize bitmasks with existing numbers
        for (int r = 0; r < 9; r++) {
            for (int c = 0; c < 9; c++) {
                if (board[r][c] != '.') {
                    int mask = 1 << (board[r][c] - '1');
                    flip(r, c, mask);
                }
            }
        }
        backtrack(board, 0, 0);
    }

private:
    bool backtrack(std::vector<std::vector<char>>& board, int r, int c) {
        // Move to next row if we reach the end of a column
        if (c == 9) return backtrack(board, r + 1, 0);
        // If we reach row 9, the puzzle is solved
        if (r == 9) return true;
        // Skip already filled cells
        if (board[r][c] != '.') return backtrack(board, r, c + 1);

        int box_idx = (r / 3) * 3 + (c / 3);

        for (int num = 0; num < 9; num++) {
            int mask = 1 << num;
            // Check if 'num' is safe to place using bitwise AND
            if (!(rows[r] & mask) && !(cols[c] & mask) && !(boxes[box_idx] & mask)) {
                
                board[r][c] = (char)('1' + num);
                flip(r, c, mask); // Set bits

                if (backtrack(board, r, c + 1)) return true;

                // Backtrack: Reset cell and bits
                board[r][c] = '.';
                flip(r, c, mask);
            }
        }
        return false;
    }

    // Toggle the bit for a specific number in row, col, and box masks
    void flip(int r, int c, int mask) {
        rows[r] ^= mask;
        cols[c] ^= mask;
        boxes[(r / 3) * 3 + (c / 3)] ^= mask;
    }
};
